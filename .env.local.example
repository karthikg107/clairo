# ─── Clairo environment variables ────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real secrets.

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Database ──────────────────────────────────────────────────────────────────
# AWS RDS PostgreSQL — fetch from AWS Secrets Manager in production
DATABASE_URL=postgresql://clairo:REPLACE_ME@localhost:5432/clairo_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
# AWS ElastiCache — fetch from AWS Secrets Manager in production
REDIS_URL=redis://localhost:6379

# ── Anthropic Claude API ─────────────────────────────────────────────────────
# NEVER expose this key client-side. Backend only.
# In production: fetched from AWS Secrets Manager at startup.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Google Cloud Vision API ───────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=REPLACE_ME
GOOGLE_CLOUD_CREDENTIALS_JSON=REPLACE_ME

# ── Stripe ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── PostHog Analytics ────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_REPLACE_ME
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Sentry ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://REPLACE_ME@sentry.io/REPLACE_ME
SENTRY_AUTH_TOKEN=REPLACE_ME

# ─── IMPORTANT ────────────────────────────────────────────────────────────────
# In production ALL secrets are stored in AWS Secrets Manager.
# The backend fetches them at startup — they are never in environment variables
# in production containers. This file is for local development ONLY.
